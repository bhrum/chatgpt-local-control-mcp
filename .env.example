# MCP HTTP endpoint
PORT=8787
MCP_PATH=/mcp

# File tools are restricted to these roots. Separate multiple paths with ":".
# Keep this narrow. Add ~/Desktop or ~/Documents only if you really want ChatGPT
# to see and modify those folders.
LOCAL_CONTROL_ROOTS="/Users/gloriachan/Documents/New project"

# Privileged tools can use this as a fallback tool argument named control_pin.
# ChatGPT OAuth authorization does not require entering this PIN by default.
LOCAL_CONTROL_PIN=change-me-to-a-long-random-secret

# Read-only tools never require auth. OAuth-authorized write/control tools get
# a bearer token with the local.control scope.
OAUTH_TOKEN_TTL_SECONDS=86400
# Optional: set to 1 if you want the OAuth authorization page to ask for the
# fallback PIN before issuing a token.
OAUTH_REQUIRE_APPROVAL_PIN=0

# Enable privileged capabilities one by one.
ALLOW_WRITES=0
ALLOW_SHELL=0
ALLOW_SCREENSHOT=0
ALLOW_OPEN=0
ALLOW_APPLESCRIPT=0

# Shell execution is never a true sandbox. By default only a small executable
# allowlist is accepted. Set ALLOW_UNSAFE_SHELL=1 only for a trusted, temporary
# local session.
ALLOW_UNSAFE_SHELL=0
SAFE_EXECUTABLES=pwd,ls,find,cat,head,tail,wc,du,df,ps,whoami,hostname,git,node,npm,python3,rg,sed

# Output and file safety limits.
MAX_COMMAND_OUTPUT_CHARS=20000
MAX_READ_BYTES=262144
MAX_DIRECTORY_ENTRIES=300
COMMAND_TIMEOUT_MS=15000
